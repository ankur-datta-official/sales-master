NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional fallback key naming used in parts of the codebase:
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for server-side user provisioning/admin API flows.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only direct Postgres connection for Prisma tooling/admin workflows.
# Use the Supabase database connection string, not NEXT_PUBLIC_SUPABASE_URL.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# Optional hardening: if set, /api/health requires bearer/query token.
HEALTHCHECK_TOKEN=
